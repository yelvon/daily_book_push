# AI（至少配置 CURSOR_API_KEY 或 GEMINI_API_KEY 之一；两者都配时 Cursor 优先）
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5

GEMINI_API_KEY=
GEMINI_MODEL=gemini/gemini-2.5-flash
GEMINI_MODEL_FALLBACK=gemini/gemini-2.0-flash
# 是否启用 Gemini 联网搜索（true/false）
GEMINI_USE_SEARCH=true

# 书籍 / 荐书频道通知（至少配置一个）
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=
FEISHU_WEBHOOK_KEYWORD=

WECHAT_WEBHOOK_URL=
# text=个人微信可查看；markdown/markdown_v2=仅企业微信客户端（需 WECHAT_PERSONAL_COMPAT=false）
WECHAT_MSG_TYPE=text
WECHAT_PERSONAL_COMPAT=true

# 经济学频道通知（独立群，可与书籍频道不同）
ECONOMICS_FEISHU_WEBHOOK_URL=
ECONOMICS_FEISHU_WEBHOOK_SECRET=
ECONOMICS_FEISHU_WEBHOOK_KEYWORD=

ECONOMICS_WECHAT_WEBHOOK_URL=
ECONOMICS_WECHAT_MSG_TYPE=text

# 法学频道通知（独立群，可与书籍/经济学频道不同）
LAW_FEISHU_WEBHOOK_URL=
LAW_FEISHU_WEBHOOK_SECRET=
LAW_FEISHU_WEBHOOK_KEYWORD=

LAW_WECHAT_WEBHOOK_URL=
LAW_WECHAT_MSG_TYPE=text

# 商业案例频道通知（独立群，可与其他频道不同）
BUSINESS_FEISHU_WEBHOOK_URL=
BUSINESS_FEISHU_WEBHOOK_SECRET=
BUSINESS_FEISHU_WEBHOOK_KEYWORD=

BUSINESS_WECHAT_WEBHOOK_URL=
BUSINESS_WECHAT_MSG_TYPE=text

# 市场事件雷达频道通知（独立群，可与其他频道不同）
MARKET_FEISHU_WEBHOOK_URL=
MARKET_FEISHU_WEBHOOK_SECRET=
MARKET_FEISHU_WEBHOOK_KEYWORD=

MARKET_WECHAT_WEBHOOK_URL=
MARKET_WECHAT_MSG_TYPE=text

# 金融投资频道通知（独立群，可与其他频道不同）
FINANCE_FEISHU_WEBHOOK_URL=
FINANCE_FEISHU_WEBHOOK_SECRET=
FINANCE_FEISHU_WEBHOOK_KEYWORD=

FINANCE_WECHAT_WEBHOOK_URL=
FINANCE_WECHAT_MSG_TYPE=text

WEBHOOK_VERIFY_SSL=true
